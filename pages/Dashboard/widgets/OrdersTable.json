      "onClick": "{{\n      OrdersTable.setSelectedRowIndex(\n        OrdersTable.tableData.findIndex(row => row.order_id === currentRow.order_id)\n      );\n      setTimeout(() => {\n        GetOrderDetails.run();\n        GetOrderItems.run();\n        showModal('OrderManagementModal');\n      }, 100);\n    }}\n  }",
