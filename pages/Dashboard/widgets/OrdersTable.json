    "customColumn2": {
      "alias": "Age",
      "allowCellWrapping": false,
      "allowSameOptionsInNewRow": true,
      "buttonStyle": "rgb(3, 179, 101)",
      "cellBackground": "",
      "columnType": "text",
      "computedValue": "{{(() => { const tableData = OrdersTable.processedTableData || []; return tableData.length > 0 ? tableData.map((currentRow, currentIndex) => ((() => {\n    const created = moment(currentRow.created_date);\n    const now = moment();\n    const hours = now.diff(created, 'hours');\n\n    if (hours < 1) return `${now.diff(created, 'minutes')} min ago`;\n    if (hours < 24) return `${hours} hours ago`;\n    if (hours < 48) return 'Yesterday';\n    return created.format('MMM DD');\n  })())) : (() => {\n    const created = moment(currentRow.created_date);\n    const now = moment();\n    const hours = now.diff(created, 'hours');\n\n    if (hours < 1) return `${now.diff(created, 'minutes')} min ago`;\n    if (hours < 24) return `${hours} hours ago`;\n    if (hours < 48) return 'Yesterday';\n    return created.format('MMM DD');\n  })() })()}}",
      "currencyCode": "USD",
      "decimals": 0,
      "enableFilter": true,
      "enableSort": true,
      "horizontalAlignment": "CENTER",
