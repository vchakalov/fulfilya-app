    "customColumn4": {
      "alias": "Payment",
      "allowCellWrapping": false,
      "allowSameOptionsInNewRow": true,
      "buttonStyle": "rgb(3, 179, 101)",
      "cellBackground": "",
      "columnType": "text",
      "computedValue": "{{(() => { const tableData = OrdersTable.processedTableData || []; return tableData.length > 0 ? tableData.map((currentRow, currentIndex) => ((() => {\n    const method = currentRow.payment_method;\n    const amount = currentRow.total_value || currentRow.cod_amount;\n\n    if (method === 'COD') {\n      return `💵 COD ${amount || ''}`;\n    } else if (method === 'Paid') {\n      return `✅ Paid`;\n    }\n    return '❓ Unknown';\n  })())) : (() => {\n    const method = currentRow.payment_method;\n    const amount = currentRow.total_value || currentRow.cod_amount;\n\n    if (method === 'COD') {\n      return `💵 COD ${amount || ''}`;\n    } else if (method === 'Paid') {\n      return `✅ Paid`;\n    }\n    return '❓ Unknown';\n  })() })()}}",
